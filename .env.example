# ─────────────────────────────────────────────────────────────────────
# .env.example — Chatbot Microterminal ThR
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env real no Git (já está no .gitignore)
# ─────────────────────────────────────────────────────────────────────

# ── Servidor ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Origens permitidas no CORS (use * em dev, domínio exato em prod)
CORS_ORIGIN=*

# ── Anthropic (Claude AI) ─────────────────────────────────────────────
# Necessário para: RAG, classificação de intenção, análise de imagens
# Obtenha em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
# Modelo padrão (não precisa alterar)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Meta WhatsApp Cloud API ───────────────────────────────────────────
# Necessário para: enviar e receber mensagens via WhatsApp oficial
# Obtenha em: developers.facebook.com → seu app → WhatsApp → API Setup
#
# Token de acesso temporário (60 dias) ou permanente via System User:
META_TOKEN=EAAxxxxxxxxxxxxxxx
# ID do número de telefone registrado no Meta (não o número em si):
META_PHONE_ID=1234567890
# Token de verificação do webhook (pode ser qualquer string segura):
META_VERIFY_TOKEN=microterminal-thr-2024

# ── Z-API (legado — pode deixar vazio se usar Meta) ───────────────────
# Usado apenas enquanto a migração para Meta não é concluída
ZAPI_INSTANCE=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# ── Transcrição de Áudio ──────────────────────────────────────────────
# GROQ é gratuito e preferido. OpenAI é fallback pago.
# Obtenha Groq em: console.groq.com → API Keys (plano gratuito disponível)
GROQ_API_KEY=gsk_...
# Alternativa paga (só preencha se não usar Groq):
OPENAI_API_KEY=

# ── Suporte Humano ────────────────────────────────────────────────────
# Número do WhatsApp que recebe notificação quando cliente pede suporte
# Formato internacional sem + (ex: 5511999999999)
SUPPORT_PHONE=5511999999999

# ── Sessões ───────────────────────────────────────────────────────────
# Tempo de inatividade até a sessão expirar (em ms). Padrão: 900000 (15min)
# Mínimo permitido: 60000 (1min)
SESSION_TIMEOUT=900000

# Caminho para salvar a sessão do WhatsApp Web (Z-API legado)
WHATSAPP_SESSION_PATH=./whatsapp-session

# ── Apenas para testes ────────────────────────────────────────────────
# Simula uma data/hora específica para testes de horário comercial
# Formato ISO 8601 local (sem Z): 2024-01-15T10:00:00
# Deixe vazio em produção
DATE_OVERRIDE=
